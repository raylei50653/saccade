[Unit]
Description=YOLO-LLM Perception (Fast Path)
After=network.target mediamtx.service
Requires=mediamtx.service

[Service]
Type=simple
User=ray
WorkingDirectory=/home/ray/developer/ai/YOLO_LLM
ExecStart=/home/ray/developer/ai/YOLO_LLM/scripts/run.sh perception

Restart=always
RestartSec=10
WatchdogSec=60

[Install]
WantedBy=multi-user.target
